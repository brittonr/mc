# This repository tracks the mc compatibility harness and its core Valence/Stevenarella component trees.
# /home/brittonr/git is otherwise a multi-repo workspace; keep sibling repos,
# scratch artifacts, and unrelated nested project checkouts out of this repo by default.
/*

# Keep this ignore policy tracked.
!/.gitignore

# Keep the scoped mc harness files tracked.
!/mc/
/mc/*
!/mc/README.md
!/mc/flake.nix
!/mc/flake.lock
!/mc/docs/
/mc/docs/*
!/mc/docs/architecture.md

# Keep the core client/server component trees tracked in this repo.
!/mc/clients/
!/mc/clients/**
!/mc/servers/
!/mc/servers/**

# Keep the compatibility harness/config/fixtures tracked in this repo.
!/mc/compat/
!/mc/compat/**
/mc/compat/**/target/

!/mc/scripts/
/mc/scripts/*
!/mc/scripts/mc-compat-smoke.sh

!/mc/tools/
/mc/tools/*

.pi/
