# This repository tracks the mc compatibility harness and its core Valence/Stevenarella component trees.
# /home/brittonr/git is otherwise a multi-repo workspace; keep sibling repos,
# scratch artifacts, and unrelated nested project checkouts out of this repo by default.
/*

# Keep this ignore policy tracked.
!/.gitignore

# Keep the scoped mc harness files tracked.
!/mc/
/mc/*
!/mc/README.md
!/mc/flake.nix
!/mc/flake.lock
!/mc/docs/
/mc/docs/*
!/mc/docs/architecture.md

# Keep the core client/server component trees tracked in this repo.
!/mc/clients/
!/mc/clients/**
!/mc/servers/
!/mc/servers/**

!/mc/config/
/mc/config/*
!/mc/config/mc-compat/
/mc/config/mc-compat/*
!/mc/config/mc-compat/default.ncl
!/mc/config/mc-compat/generated/
/mc/config/mc-compat/generated/*
!/mc/config/mc-compat/generated/default.json

!/mc/scripts/
/mc/scripts/*
!/mc/scripts/mc-compat-smoke.sh

!/mc/tools/
/mc/tools/*
!/mc/tools/mc-compat-runner/
/mc/tools/mc-compat-runner/*
!/mc/tools/mc-compat-runner/Cargo.lock
!/mc/tools/mc-compat-runner/Cargo.toml
!/mc/tools/mc-compat-runner/src/
/mc/tools/mc-compat-runner/src/*
!/mc/tools/mc-compat-runner/src/main.rs
!/mc/tools/mc-compat-runner/src/layout.rs

.pi/
