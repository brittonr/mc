+
+fn survival_hunger_profile_from_flags(
+    food_enabled: bool,
+    health_enabled: bool,
+) -> Option<SurvivalHungerProfile> {
+    match (food_enabled, health_enabled) {
+        (false, false) => None,
+        (true, false) => Some(SURVIVAL_HUNGER_FOOD_PROFILE),
+        (false, true) | (true, true) => Some(SURVIVAL_HUNGER_HEALTH_PROFILE),
+    }
+}
