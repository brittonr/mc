+fn vanilla_combat_reference_assignment_for(
+    enabled: bool,
+    username: &str,
+) -> Option<VanillaCombatReferenceAssignment> {
+    if !enabled {
+        return None;
+    }
+    match username {
+        VANILLA_COMBAT_REFERENCE_ATTACKER => Some(VanillaCombatReferenceAssignment {
