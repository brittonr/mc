+                VANILLA_COMBAT_REFERENCE_Y,
+                VANILLA_COMBAT_REFERENCE_Z,
+            ]
+            .into(),
+            yaw: VANILLA_COMBAT_REFERENCE_VICTIM_YAW,
+        }),
+        _ => None,
+    }
+}
