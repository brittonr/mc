+#[cfg(not(target_arch = "wasm32"))]
+fn control_command_requires_connected(command: &control::ControlCommand) -> bool {
+    !matches!(
+        command,
+        control::ControlCommand::Status
+            | control::ControlCommand::Connect { .. }
+            | control::ControlCommand::Disconnect
+    )
+}
