+            Hand::Main,
+            survival_crafting_pos()
+        ));
+        assert!(!should_open_survival_crafting(
+            GameMode::Survival,
+            Hand::Off,
+            survival_crafting_pos()
+        ));
+        assert!(!should_open_survival_crafting(
