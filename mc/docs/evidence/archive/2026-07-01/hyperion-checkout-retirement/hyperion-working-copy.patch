+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum FeatureDependencyStatus {
+    Present,
+    FeatureDisabled,
+    DependencyDisabled,
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct FeatureDependencyDiagnostic {
+    pub feature: GameplayFeature,
+    pub dependency: GameplayFeature,
+    pub status: FeatureDependencyStatus,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct PresetDiagnostics {
+    pub mode: ExclusiveMode,
+    pub include_default_gameplay: bool,
+    pub installed_features: Vec<GameplayFeature>,
+    pub disabled_features: Vec<GameplayFeature>,
+    pub replacement_features: Vec<GameplayFeature>,
+    pub custom_plugins: Vec<&'static str>,
+    pub dependency_decisions: Vec<FeatureDependencyDiagnostic>,
+    pub non_claims: Vec<&'static str>,
+}
+
+pub fn build_preset_diagnostics(plan: &PresetPlan) -> PresetDiagnostics {
+    let installed_features = installed_default_features(plan);
+    let dependency_decisions = feature_dependency_diagnostics(plan);
+    PresetDiagnostics {
+        mode: plan.mode,
+        include_default_gameplay: plan.include_default_gameplay,
+        installed_features,
+        disabled_features: plan.disabled_features.clone(),
+        replacement_features: plan.replacement_features.clone(),
+        custom_plugins: plan.custom_plugins.clone(),
+        dependency_decisions,
+        non_claims: COMPILED_PLUGIN_NON_CLAIMS.to_vec(),
+    }
+}
+
+fn installed_default_features(plan: &PresetPlan) -> Vec<GameplayFeature> {
+    if !plan.include_default_gameplay {
+        return Vec::new();
+    }
+    DEFAULT_GAMEPLAY_FEATURES
+        .iter()
+        .copied()
+        .filter(|feature| {
+            !plan.disabled_features.contains(feature)
+                && !plan.replacement_features.contains(feature)
+        })
+        .collect()
+}
+
+fn feature_dependency_diagnostics(plan: &PresetPlan) -> Vec<FeatureDependencyDiagnostic> {
+    DEFAULT_GAMEPLAY_FEATURES
+        .iter()
+        .copied()
+        .flat_map(|feature| {
+            feature
+                .dependencies()
+                .iter()
+                .copied()
+                .map(move |dependency| FeatureDependencyDiagnostic {
+                    feature,
+                    dependency,
+                    status: feature_dependency_status(plan, feature, dependency),
+                })
+        })
+        .collect()
+}
+
+fn feature_dependency_status(
+    plan: &PresetPlan,
+    feature: GameplayFeature,
+    dependency: GameplayFeature,
+) -> FeatureDependencyStatus {
+    if !plan.include_default_gameplay
+        || plan.disabled_features.contains(&feature)
+        || plan.replacement_features.contains(&feature)
+    {
+        return FeatureDependencyStatus::FeatureDisabled;
+    }
+    if plan.disabled_features.contains(&dependency)
+        || plan.replacement_features.contains(&dependency)
+    {
+        return FeatureDependencyStatus::DependencyDisabled;
+    }
+    FeatureDependencyStatus::Present
+}
