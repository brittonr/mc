+pub fn validate_plugin_diagnostics(
+    diagnostics: &PresetDiagnostics,
+    plan: &PresetPlan,
+) -> Result<(), PluginDiagnosticsMismatch> {
+    let expected = build_preset_diagnostics(plan);
+    if diagnostics.mode != expected.mode {
+        return Err(PluginDiagnosticsMismatch::Mode);
+    }
+    if diagnostics.include_default_gameplay != expected.include_default_gameplay {
+        return Err(PluginDiagnosticsMismatch::DefaultGameplay);
+    }
+    if diagnostics.installed_features != expected.installed_features {
+        return Err(PluginDiagnosticsMismatch::InstalledFeatures);
+    }
+    if diagnostics.disabled_features != expected.disabled_features {
+        return Err(PluginDiagnosticsMismatch::DisabledFeatures);
+    }
+    if diagnostics.replacement_features != expected.replacement_features {
+        return Err(PluginDiagnosticsMismatch::ReplacementFeatures);
+    }
+    if diagnostics.custom_plugins != expected.custom_plugins {
+        return Err(PluginDiagnosticsMismatch::CustomPlugins);
+    }
+    if diagnostics.dependency_decisions != expected.dependency_decisions {
+        return Err(PluginDiagnosticsMismatch::DependencyDecisions);
+    }
+    if diagnostics.non_claims != expected.non_claims {
+        return Err(PluginDiagnosticsMismatch::NonClaims);
+    }
+    Ok(())
+}
+
+pub fn validate_plugin_diagnostics_registry(
