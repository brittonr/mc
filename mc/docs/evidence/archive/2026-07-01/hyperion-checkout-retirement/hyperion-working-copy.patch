+fn validate_executable_plugin_slots(
+    preset: &GamePreset,
+    plan: &PresetPlan,
+) -> Result<(), CompositionError> {
+    validate_replacement_plugin_slots(preset, plan)?;
+    validate_custom_plugin_slots(preset, plan)
+}
+
+fn validate_replacement_plugin_slots(
+    preset: &GamePreset,
+    plan: &PresetPlan,
+) -> Result<(), CompositionError> {
+    for &feature in &plan.replacement_features {
+        if replacement_plugin_slot(preset, feature).is_none() {
+            return Err(CompositionError::MissingReplacementPluginSlot(feature));
+        }
+    }
+    for slot in &preset.replacement_plugin_slots {
+        if !plan.replacement_features.contains(&slot.feature) {
+            return Err(CompositionError::UnexpectedReplacementPluginSlot(
+                slot.feature,
+            ));
+        }
+    }
+    Ok(())
+}
+
+fn validate_custom_plugin_slots(
+    preset: &GamePreset,
+    plan: &PresetPlan,
+) -> Result<(), CompositionError> {
+    for &plugin_name in &plan.custom_plugins {
+        if custom_plugin_slot(preset, plugin_name).is_none() {
+            return Err(CompositionError::MissingCustomPluginSlot(plugin_name));
+        }
+    }
+    for slot in &preset.custom_plugin_slots {
+        if !plan.custom_plugins.contains(&slot.name) {
+            return Err(CompositionError::UnexpectedCustomPluginSlot(slot.name));
+        }
+    }
+    Ok(())
+}
+
+fn replacement_plugin_slot(
+    preset: &GamePreset,
+    feature: GameplayFeature,
+) -> Option<PresetFeatureReplacementSlot> {
+    preset
+        .replacement_plugin_slots
+        .iter()
+        .copied()
+        .find(|slot| slot.feature == feature)
+}
+
+fn custom_plugin_slot(preset: &GamePreset, plugin_name: &str) -> Option<PresetPluginSlot> {
+    preset
+        .custom_plugin_slots
+        .iter()
+        .copied()
+        .find(|slot| slot.name == plugin_name)
+}
+
+fn apply_preset_plugin_slots(app: &mut App, preset: &GamePreset, plan: &PresetPlan) {
+    for &feature in &plan.replacement_features {
+        let slot = replacement_plugin_slot(preset, feature).expect("validated replacement slot");
+        slot.slot.install(app);
+    }
+    for &plugin_name in &plan.custom_plugins {
+        let slot = custom_plugin_slot(preset, plugin_name).expect("validated custom plugin slot");
+        slot.install(app);
+    }
+}
+
+fn join_feature_names(features: &[GameplayFeature]) -> String {
+    features
+        .iter()
+        .copied()
+        .map(GameplayFeature::name)
+        .collect::<Vec<_>>()
+        .join(",")
+}
