let Contracts = import "contracts.ncl" in
{
  name = "cairn-default",
  version = 1,

  schemas = [{
    id = "spec-driven",
    description = "OpenSpec proposal/spec/design/tasks lifecycle",
    artifacts = [
      { id = "proposal", generates = "proposal.md", requires = [] },
      { id = "specs", generates = "specs/**/*.md", requires = ["proposal"] },
      { id = "design", generates = "design.md", requires = ["proposal"] },
      { id = "tasks", generates = "tasks.md", requires = ["specs", "design"] },
    ],
  }],

  lifecycle_stages = ["proposal", "design", "tasks", "implementation", "archive"],

  task_marker_policy = {
    enabled = true,
    stages = ["tasks"],
    strictness = "strict",
    ignore_archives = true,
    markers = [
      { id = "parallel", token = "[parallel]", kind = "literal" },
      { id = "serial", token = "[serial]", kind = "literal" },
      { id = "depends", token = "[depends:<task-or-id>]", kind = "depends-prefix" },
    ],
  },

  finding_defaults = {
    severity = "high",
    class = "omission",
    scope = "tasks",
    route = "auto-fix",
    promoted = "no",
  },

  gate_policy = {
    stages = ["proposal", "design", "tasks"],
    ignore_archives = true,
    finding = {
      severity = "high",
      class = "omission",
      scope = "tasks",
      route = "auto-fix",
      promoted = "no",
    },
  },

  report_contract = {
    verdicts = ["PASS", "WARN", "FAIL"],
    sections = ["Findings", "Required Fixes", "OpenSpec Check", "Gaps", "Next Steps"],
    tagged_findings_required_fields = ["class", "scope", "route", "promoted"],
  },

  registry_label_policy = {
    channels = ["dev", "nightly", "release", "stable"],
    platforms = ["aarch64-darwin", "aarch64-linux", "x86_64-darwin", "x86_64-linux"],
    compatibility_classes = ["current", "experimental", "legacy"],
    release_format = "YYYY-MM-DD",
  },

  change_metadata_policy = {
    allowed_groups = ["current", "future"],
    group_prefixes = ["feature:"],
    statuses = ["current", "planned", "blocked", "deferred"],
  },

  steel_orchestration_policy = {
    enabled = false,
    profiles = [{
      id = "disabled.lifecycle.default",
      mode = "disabled",
      allowed_host_functions = [],
      deterministic_budgets = ["no-evaluation"],
      redaction_classes = ["no-secret-fields"],
      fallback_modes = ["rust-nickel-canonical"],
      receipt_schema_version = "cairn.steel-orchestration-receipt.v1",
    }],
  },

  probe_policy = {
    enabled = true,
    inline_gate_execution_enabled = false,
    receipt_schema_version = "cairn.probe-receipt.v1",
    coverage_classes = ["positive", "negative", "malformed-input", "boundary", "regression"],
    command_profiles = [{
      id = "cairn-local",
      commands = ["archive", "doctor", "gate", "policy", "sync", "test-harness", "tracey", "validate"],
      capability_classes = ["local-process", "bounded-stdout-stderr-hashes", "optional-fixture-mutation"],
    }],
    redaction_classes = ["hash-stdout", "hash-stderr", "no-secret-fields"],
  },

  receipt_schemas = [
    {
      command = "steel orchestration",
      top_level_keys = ["authorized_actions", "command", "fallback_reason", "issues", "mode", "profile_id", "receipt_hash", "schema_version", "script_hash", "valid", "verdict"],
      action_keys = ["host_function", "id", "request_hash"],
      issue_keys = ["code", "field_path", "message"],
